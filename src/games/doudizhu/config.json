  "l2": {
    "rules": [
      {
        "trigger": "on_game_start",
        "actions": [
          {
            "type": "deal_cards"
          },
          {
            "type": "enter_calling"
          }
        ]
      },
      {
        "trigger": "on_call_phase",
        "actions": [
          {
            "type": "wait_for_call"
          }
        ]
      },
      {
        "trigger": "on_landlord_chosen",
        "actions": [
          {
            "type": "give_bottom_cards"
          },
          {
            "type": "enter_playing"
          }
        ]
      },
      {
        "trigger": "on_turn_start",
        "actions": [
          {
            "type": "wait_for_play"
          }
        ]
      },
      {
        "trigger": "on_card_played",
        "actions": [
          {
            "type": "validate_pattern"
          },
          {
            "type": "update_discard"
          },
          {
            "type": "next_turn"
          }
        ]
      },
      {
        "trigger": "on_pass",
        "actions": [
          {
            "type": "next_turn"
          }
        ]
      },
      {
        "trigger": "on_cards_empty",
        "actions": [
          {
            "type": "declare_winner"
          }
        ]
      }
    ]
  },
  "l3": "// 斗地主牌型识别\n// 由 l3_pattern.test.ts 编译生成\nregisterFunction('checkPattern', function(state, cards) {\n  var n = cards.length;\n  if (n === 0) return null;\n  if (n === 2) {\n    var ranks = cards.map(function(c) { return c.rank; });\n    if (ranks.indexOf('small_joker') >= 0 && ranks.indexOf('big_joker') >= 0) {\n      return { type: 'rocket', mainValue: 18 };\n    }\n  }\n  var counts = new Map();\n  for (var i = 0; i < cards.length; i++) {\n    var v = cards[i].value;\n    counts.set(v, (counts.get(v) || 0) + 1);\n  }\n  var values = Array.from(counts.keys()).sort(function(a, b) { return a - b; });\n  var countVals = Array.from(counts.values());\n  if (n === 4 && counts.size === 1) return { type: 'bomb', mainValue: values[0] };\n  if (n === 1) return { type: 'single', mainValue: values[0] };\n  if (n === 2 && counts.size === 1) return { type: 'pair', mainValue: values[0] };\n  if (n === 3 && counts.size === 1) return { type: 'triple', mainValue: values[0] };\n  if (n === 4 && countVals.indexOf(3) >= 0 && countVals.indexOf(1) >= 0) {\n    var tv = values.find(function(v) { return counts.get(v) === 3; });\n    return { type: 'triple_single', mainValue: tv };\n  }\n  if (n === 5 && countVals.indexOf(3) >= 0 && countVals.indexOf(2) >= 0) {\n    var tv2 = values.find(function(v) { return counts.get(v) === 3; });\n    return { type: 'triple_pair', mainValue: tv2 };\n  }\n  if (n >= 5 && countVals.every(function(c) { return c === 1; })) {\n    var straight = true;\n    for (var j = 1; j < values.length; j++) { if (values[j] !== values[j-1] + 1) { straight = false; break; } }\n    if (straight && values[values.length-1] < 15) return { type: 'straight', mainValue: values[values.length-1], length: n };\n  }\n  if (n >= 6 && n % 2 === 0 && countVals.every(function(c) { return c === 2; })) {\n    var sp = true;\n    for (var k = 1; k < values.length; k++) { if (values[k] !== values[k-1] + 1) { sp = false; break; } }\n    if (sp && values[values.length-1] < 15) return { type: 'straight_pair', mainValue: values[values.length-1], length: n/2 };\n  }\n  return null;\n});\n\nregisterFunction('comparePatterns', function(state, a, b) {\n  if (a.type === 'rocket') return 1;\n  if (b.type === 'rocket') return -1;\n  if (a.type === 'bomb' && b.type !== 'bomb') return 1;\n  if (b.type === 'bomb' && a.type !== 'bomb') return -1;\n  if (a.type === b.type && a.length === b.length) return a.mainValue - b.mainValue;\n  return 0;\n});\n"
}